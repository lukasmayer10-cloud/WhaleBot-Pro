MODE=paper

# Server bind (Docker sets WHALEBOT_HOST=0.0.0.0)
WHALEBOT_HOST=127.0.0.1
PORT=8080

# Binance Futures Testnet only
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Live keys intentionally disabled until later version
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_API_SECRET=

# Safety
ALLOW_LIVE_TRADING=false
ALLOW_TESTNET_TRADING=false

# Optional Telegram alerts (leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_LEVELS=TRADE,ERROR,WARN

# Optional path overrides (Docker mounts a volume here)
# WHALEBOT_DATA_DIR=./data
# WHALEBOT_LOG_DIR=./logs
